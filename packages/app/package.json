{
  "name": "@workerking/app",
  "version": "0.0.0",
  "private": true,
  "description": "WorkerKing Electron shell: overlay avatar window, chat window, tray, daemon supervisor. Windows-only at runtime.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "start": "electron-vite preview",
    "package": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@workerking/shared": "workspace:*",
    "@workerking/voice-providers": "workspace:*",
    "electron-store": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "electron": "^33.2.1",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
