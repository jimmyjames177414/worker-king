{
  "name": "worker-king",
  "version": "0.0.0",
  "private": true,
  "description": "WorkerKing — a personal Jarvis-style AI assistant for Windows, powered by Claude Code.",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:headless": "pnpm --filter @workerking/shared --filter @workerking/core --filter @workerking/voice-providers --filter @workerking/wakeword-openwakeword --filter @workerking/app run test",
    "eval": "pnpm --filter @workerking/core run eval",
    "daemon": "pnpm --filter @workerking/core run start",
    "app": "pnpm --filter @workerking/app run dev",
    "lint": "eslint packages",
    "lint:fix": "eslint packages --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.9"
  }
}
